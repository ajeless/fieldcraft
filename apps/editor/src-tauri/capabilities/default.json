{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Fieldcraft default desktop permissions.",
  "windows": [
    "main"
  ],
  "permissions": [
    "dialog:allow-message",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**",
        "$TEMP/**"
      ]
    },
    "fs:allow-copy-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file"
  ]
}
